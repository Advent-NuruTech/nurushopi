# ============================================================
# NuruShop Firebase -> PostgreSQL migration utility
# Copy to `.env` and fill in. This file is read ONLY by the
# migration tool (apps/migrate). It is never imported by the
# production app or API.
# ============================================================

# --- Target PostgreSQL (the NEW database) ----------------------------------
# Use the SAME values your API uses. DIRECT_URL bypasses the pooler — strongly
# preferred for a bulk migration (avoids PgBouncer transaction-mode limits).
DATABASE_URL="postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"

# --- Source Firebase (the OLD project) -------------------------------------
# Service-account credentials with read access to Firestore + Auth.
# Option A (recommended): absolute path to the service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS="C:/secrets/nurushop-firebase-adminsdk.json"
# Option B: inline the JSON (single line). Used only if the path above is unset.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}'
FIREBASE_PROJECT_ID="your-firebase-project-id"

# --- Behaviour --------------------------------------------------------------
# Read/insert this many docs per batch. Each batch is one Postgres transaction.
BATCH_SIZE="400"
# true = transform + log only, write NOTHING to Postgres. Always run this first.
DRY_RUN="false"
# How many failed batches to retry before giving up on a collection.
MAX_RETRIES="3"
# Where to write logs and reports.
OUT_DIR="./out"

# --- Validation: live API smoke tests (optional) ---------------------------
# Base URL of the running Express API, e.g. http://localhost:4000/api/v1
API_BASE_URL="http://localhost:4000/api/v1"

# --- Password migration -----------------------------------------------------
# Firebase password hashes are scrypt and CANNOT be verified by bcrypt.
# See README "Password migration". When EXPORT_PASSWORD_HASHES=true the tool
# writes each user's scrypt hash + salt to out/firebase-password-hashes.json
# AND (if the LegacyPasswordImport model exists) into Postgres, enabling a
# zero-friction "lazy rehash" login. The project-wide scrypt params below come
# from Firebase console -> Authentication -> (3-dot menu) -> Password hash params.
EXPORT_PASSWORD_HASHES="true"
FIREBASE_SCRYPT_SIGNER_KEY=""
FIREBASE_SCRYPT_SALT_SEPARATOR="Bw=="
FIREBASE_SCRYPT_ROUNDS="8"
FIREBASE_SCRYPT_MEM_COST="14"
