// NuruShop — Prisma schema (full domain)
// Provider: PostgreSQL (Supabase now; portable to AWS RDS / any Postgres by swapping env URLs).
// Money is stored as Decimal(12,2). Ids are cuid() strings.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Enums
// ============================================================

enum AdminRole {
  SENIOR
  SUB
}

enum AdminInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WalletTxType {
  CREDIT
  DEBIT
}

enum WalletTxSource {
  AFFILIATE
  REDEEM
  ADJUSTMENT
  REFUND
}

enum WalletTxStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum NotificationRecipientType {
  USER
  ADMIN
}

enum MessageSenderType {
  USER
  ADMIN
}

enum VendorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// Identity & Auth
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String? // null for OAuth-only accounts
  name          String?
  phone         String?
  avatarUrl     String?
  emailVerified DateTime?
  isActive      Boolean   @default(true)

  // Wallet / referral program
  walletBalance Decimal @default(0) @db.Decimal(12, 2)
  referralCode  String? @unique
  referredById  String?
  referredBy    User?   @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals     User[]  @relation("UserReferrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  oauthAccounts          OAuthAccount[]
  refreshTokens          RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens    PasswordResetToken[]
  orders                 Order[]
  reviews                Review[]
  walletTransactions     WalletTransaction[]
  walletRedemptions      WalletRedemption[]
  sentMessages           Message[]               @relation("UserMessages")
  vendorApplications     VendorApplication[]
  referralEvents         Referral[]              @relation("ReferralReferrer")
  referredEvents         Referral[]              @relation("ReferralReferred")

  @@index([referredById])
  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String // "google"
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// Refresh tokens are stored hashed. `familyId` ties a rotation chain together
// so that reuse of a revoked token can revoke the whole family.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  familyId  String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// Brute-force lockout tracking, keyed by the login identifier (email).
model LoginAttempt {
  id            String    @id @default(cuid())
  identifier    String    @unique // lowercased email
  failedCount   Int       @default(0)
  lockedUntil   DateTime?
  lastAttemptAt DateTime  @default(now())

  @@map("login_attempts")
}

// ============================================================
// Admin
// ============================================================

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(SUB)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  logs           AdminLog[]
  createdProducts Product[]      @relation("ProductCreatedBy")
  invitesSent    AdminInvite[]   @relation("InviteCreatedBy")

  @@map("admins")
}

model AdminInvite {
  id          String            @id @default(cuid())
  email       String
  role        AdminRole         @default(SUB)
  tokenHash   String            @unique
  status      AdminInviteStatus @default(PENDING)
  createdById String?
  createdBy   Admin?            @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime          @default(now())

  @@index([email])
  @@map("admin_invites")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity, entityId])
  @@map("admin_logs")
}

// ============================================================
// Catalog
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String?  @unique
  description      String?
  shortDescription String?
  price            Decimal  @db.Decimal(12, 2)
  originalPrice    Decimal? @db.Decimal(12, 2)
  sellingPrice     Decimal? @db.Decimal(12, 2)
  images           String[] // Cloudinary URLs (up to 3)
  stock            Int      @default(0)
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   Admin?  @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  reviews    Review[]

  @@index([categoryId])
  @@index([createdById])
  @@map("products")
}

model Banner {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model HeroAnnouncement {
  id        String   @id @default(cuid())
  message   String
  linkUrl   String?
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_announcements")
}

model WholesaleItem {
  id          String   @id @default(cuid())
  name        String
  slug        String?  @unique
  description String?
  unitPrice   Decimal  @db.Decimal(12, 2)
  minQuantity Int      @default(1)
  images      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("wholesale_items")
}

// ============================================================
// Commerce
// ============================================================

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique @default(cuid())
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)

  subtotal     Decimal @db.Decimal(12, 2)
  walletApplied Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @db.Decimal(12, 2)

  // Snapshot of contact / delivery details
  contactName  String?
  contactPhone String?
  contactEmail String?
  address      String?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Snapshot fields so history survives product edits/deletes
  productName String
  unitPrice   Decimal @db.Decimal(12, 2)
  quantity    Int
  imageUrl    String?

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Review {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([productId, status])
  @@index([userId])
  @@map("reviews")
}

// ============================================================
// Wallet / referral
// ============================================================

model WalletTransaction {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         WalletTxType
  source       WalletTxSource
  amount       Decimal        @db.Decimal(12, 2)
  balanceAfter Decimal        @db.Decimal(12, 2)
  status       WalletTxStatus @default(APPROVED)
  orderId      String?
  redemptionId String?
  metadata     Json?
  createdAt    DateTime       @default(now())

  @@index([userId])
  @@map("wallet_transactions")
}

model WalletRedemption {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal          @db.Decimal(12, 2)
  status    RedemptionStatus @default(PENDING)
  method    String? // e.g. "mpesa", "bank"
  details   Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@map("wallet_redemptions")
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId   String
  referred     User     @relation("ReferralReferred", fields: [referredId], references: [id], onDelete: Cascade)
  rewardAmount Decimal  @default(0) @db.Decimal(12, 2)
  rewarded     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([referredId]) // a user can only be referred once
  @@index([referrerId])
  @@map("referrals")
}

// ============================================================
// Engagement
// ============================================================

model Notification {
  id            String                    @id @default(cuid())
  recipientType NotificationRecipientType
  recipientId   String? // userId or adminId; null = broadcast
  title         String
  body          String?
  type          String? // "order", "security", "system", ...
  relatedId     String?
  read          Boolean                   @default(false)
  createdAt     DateTime                  @default(now())

  @@index([recipientType, recipientId, read])
  @@map("notifications")
}

model Message {
  id            String            @id @default(cuid())
  threadId      String
  senderType    MessageSenderType
  senderUserId  String?
  senderUser    User?             @relation("UserMessages", fields: [senderUserId], references: [id], onDelete: SetNull)
  senderAdminId String?
  body          String
  attachments   String[]
  read          Boolean           @default(false)
  createdAt     DateTime          @default(now())

  @@index([threadId, createdAt])
  @@index([senderUserId])
  @@map("messages")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  subject   String?
  message   String
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contacts")
}

model VendorApplication {
  id          String                  @id @default(cuid())
  userId      String?
  user        User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  businessName String
  contactName String?
  email       String
  phone       String?
  description String?
  status      VendorApplicationStatus @default(PENDING)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([userId])
  @@index([status])
  @@map("vendor_applications")
}

model PwaInstall {
  id        String   @id @default(cuid())
  userId    String?
  platform  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("pwa_installs")
}

model SabbathMessage {
  id        String   @id @default(cuid())
  message   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sabbath_messages")
}
